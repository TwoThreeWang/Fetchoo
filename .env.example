# Brave Search API Key（可选）
# 用于所有抓取方式失败后的最终兜底搜索
# 免费额度：2000 次/月
# 获取地址：https://api.search.brave.com
BRAVE_API_KEY=

# Firecrawl API Key（可选）
# 自带 stealth 代理，绕 Cloudflare 等反爬，放在 Browser 和 WebPageSnap 之间
# 免费额度：500 次/月
# 获取地址：https://www.firecrawl.dev
FIRECRAWL_API_KEY=

# 时区（可选）
TZ=Asia/Shanghai

# 入站 API 限速 (每秒最大请求数，0 表示不限速，留空默认值为 5)
RATE_LIMIT=5